# Bybit API credentials — create at https://www.bybit.com (testnet: https://testnet.bybit.com)
# NEVER commit the real .env. On VPS, whitelist the key to the VPS static IP.
BYBIT_API_KEY=your_key_here
BYBIT_API_SECRET=your_secret_here

# Telegram alerts (optional): create bot via @BotFather; get chat id from getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Dashboard auth token (required if dashboard is exposed beyond localhost)
DASHBOARD_TOKEN=
